  "productName": "bds-launcher",
  "version": "0.1.4",
  "identifier": "com.werewolf.bdslauncher",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
